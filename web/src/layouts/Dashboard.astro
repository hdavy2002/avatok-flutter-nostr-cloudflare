---
// Creator dashboard shell — on-brand with the avatok home page (zine design:
// cream paper, ink borders, hard shadows, Fredoka headings / Nunito body, lime
// + blue + coral accents). Left rail grouped Featured / Studio / Apps / Account,
// colour-chipped icon rows with an active state, a sticky page header with the
// page title + a New-listing CTA, and the auth/profile card (SidebarUser) pinned
// to the bottom. AvaTOK is intentionally absent (phone-only). Anything that uses
// camera / mic / speaker lives in the phone app; the web manages listings, money
// and account.
import Base from './Base.astro';
import SidebarUser from '../islands/shell/SidebarUser.tsx';

export interface Props {
  title?: string;
  /** Heading shown in the page header. Defaults to `title` minus the suffix. */
  heading?: string;
  /** Short caption under the heading. */
  subtitle?: string;
  /** Which sidebar item is active (matches an item `key`). */
  active?: string;
}
const { title = 'Dashboard · avatok.ai', heading, subtitle, active = 'overview' } = Astro.props;

Astro.response.headers.set('Cache-Control', 'private, no-store');

type Item = { key: string; label: string; icon: string; href: string; tone: string; pill?: string };

// Stroke icons (viewBox 24).
const I = {
  grid: '<rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/>',
  store: '<path d="M3 9l1.5-5h15L21 9M4 9v10a1 1 0 001 1h14a1 1 0 001-1V9M4 9h16"/>',
  folder: '<path d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>',
  list: '<path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>',
  check: '<path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>',
  broadcast: '<polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/>',
  calendar: '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>',
  eye: '<path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>',
  mic: '<rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 11a7 7 0 0014 0M12 18v3"/>',
  video: '<rect x="2" y="6" width="14" height="12" rx="2"/><path d="M16 10l6-3v10l-6-3"/>',
  inbox: '<path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.5 5h13l3.5 7v6a1 1 0 01-1 1H3a1 1 0 01-1-1v-6z"/>',
  storage: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.7 4 3 9 3s9-1.3 9-3V5M3 11v6c0 1.7 4 3 9 3s9-1.3 9-3v-6"/>',
  megaphone: '<path d="M3 11v2a1 1 0 001 1h2l4 4V6L6 10H4a1 1 0 00-1 1z"/><path d="M14 8a4 4 0 010 8M10 6l9-3v18l-9-3"/>',
  wallet: '<rect x="2" y="6" width="20" height="14" rx="3"/><path d="M16 13h2"/>',
  dollar: '<line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9a3 3 0 100 6h6a3 3 0 110 6H6"/>',
  id: '<rect x="2" y="5" width="20" height="14" rx="2"/><circle cx="8" cy="11" r="2.2"/><path d="M5 16c.6-1.6 2-2.4 3-2.4s2.4.8 3 2.4M14 9h5M14 13h5"/>',
  card: '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/>',
  gear: '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 11-4 0v-.09A1.65 1.65 0 008 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06A1.65 1.65 0 004.6 16a1.65 1.65 0 00-1.51-1H3a2 2 0 110-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06A1.65 1.65 0 008 4.6a1.65 1.65 0 001-1.51V3a2 2 0 114 0v.09A1.65 1.65 0 0016 4.6a1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0020.4 9c.14.46.5.86 1.01 1H22a2 2 0 110 4h-.09c-.51.14-.87.54-1.01 1z"/>',
};

const groups: { title: string; items: Item[] }[] = [
  { title: 'Featured', items: [
    { key: 'overview', label: 'Dashboard', icon: I.grid, href: '/dashboard', tone: 'bg-lilac' },
    { key: 'marketplace', label: 'Marketplace', icon: I.store, href: '/dashboard/marketplace', tone: 'bg-blue' },
    { key: 'library', label: 'Library', icon: I.folder, href: '/dashboard/library', tone: 'bg-mint' },
  ]},
  { title: 'Studio', items: [
    { key: 'listings', label: 'My listings', icon: I.list, href: '/dashboard/listings', tone: 'bg-lime' },
    { key: 'bookings', label: 'Bookings', icon: I.check, href: '/dashboard/bookings', tone: 'bg-card' },
    { key: 'live', label: 'AvaLive', icon: I.broadcast, href: '/dashboard/live', tone: 'bg-coral' },
    { key: 'calendar', label: 'AvaCalendar', icon: I.calendar, href: '/dashboard/calendar', tone: 'bg-card' },
  ]},
  { title: 'Apps', items: [
    { key: 'vision', label: 'AvaVision', icon: I.eye, href: '/dashboard/vision', tone: 'bg-blue' },
    { key: 'voice', label: 'AvaVoice', icon: I.mic, href: '/dashboard/voice', tone: 'bg-lilac' },
    { key: 'consult', label: 'AvaConsult', icon: I.video, href: '/dashboard/consult', tone: 'bg-mint' },
    { key: 'inbox', label: 'AvaInbox', icon: I.inbox, href: '/dashboard/inbox', tone: 'bg-card' },
    { key: 'storage', label: 'AvaStorage', icon: I.storage, href: '/dashboard/storage', tone: 'bg-card' },
    { key: 'affiliate', label: 'AvaAffiliate', icon: I.megaphone, href: '/dashboard/affiliate', tone: 'bg-coral' },
  ]},
  { title: 'Account', items: [
    { key: 'wallet', label: 'Wallet', icon: I.wallet, href: '/dashboard/wallet', tone: 'bg-lime' },
    { key: 'payout', label: 'Payout', icon: I.dollar, href: '/dashboard/payout', tone: 'bg-mint' },
    { key: 'identity', label: 'AvaIdentity', icon: I.id, href: '/dashboard/identity', tone: 'bg-blue' },
    { key: 'billing', label: 'Billing', icon: I.card, href: '/dashboard/billing', tone: 'bg-card' },
    { key: 'settings', label: 'Settings', icon: I.gear, href: '/dashboard/settings', tone: 'bg-card' },
  ]},
];

const heads = heading ?? (title.split(' · ')[0]);
---

<Base title={title} chrome={false} noindex={true}>
  <div class="flex min-h-screen bg-paper">
    <!-- Scrim (mobile) -->
    <div id="dash-scrim" class="fixed inset-0 z-40 hidden bg-ink/40 lg:hidden"></div>

    <!-- Sidebar -->
    <aside
      id="dash-sidebar"
      class="fixed inset-y-0 left-0 z-50 flex w-[272px] -translate-x-full flex-col border-r-zine border-ink bg-paper2 transition-transform duration-200 ease-out lg:sticky lg:top-0 lg:h-screen lg:translate-x-0"
    >
      <!-- Brand -->
      <div class="flex items-center gap-2 border-b-zine border-ink px-5 py-4">
        <a href="/" class="flex items-center gap-2 no-underline" aria-label="avatok.ai home">
          <svg width="26" height="24" viewBox="0 0 26 24" aria-hidden="true"><path d="M3 21 L13 3 L23 21" fill="none" stroke="var(--zine-blueInk)" stroke-width="4.6" stroke-linecap="round" stroke-linejoin="round"></path><circle cx="13" cy="16.2" r="1.9" fill="var(--zine-coral)"></circle></svg>
          <span class="font-display font-semibold text-[21px] leading-none tracking-[-0.4px] text-ink">ava<span class="text-blueInk">TOK</span></span>
        </a>
        <button id="dash-close" type="button" aria-label="Close menu" class="ml-auto flex h-8 w-8 items-center justify-center rounded-zineBadge border-zine border-ink bg-card shadow-zine-xs lg:hidden">✕</button>
      </div>

      <!-- Nav -->
      <nav class="flex-1 overflow-y-auto px-3 py-3">
        {groups.map((g) => (
          <div class="mb-3">
            <div class="px-3 pb-1.5 pt-2 font-mono font-bold uppercase text-[10px] tracking-[0.12em] text-inkMute">{g.title}</div>
            {g.items.map((it) => (
              <a
                href={it.href}
                class={`group mb-0.5 flex items-center gap-3 rounded-zineField px-2.5 py-2 no-underline font-body font-extrabold text-[14.5px] transition-transform duration-zine ${active === it.key ? 'bg-ink text-paper shadow-zine-xs' : 'text-inkSoft hover:-translate-y-[1px] hover:text-ink'}`}
              >
                <span class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-zineBadge border-zine border-ink ${active === it.key ? 'bg-paper text-ink' : `${it.tone} text-ink`} shadow-zine-xs`}>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={it.icon} />
                </span>
                <span class="truncate">{it.label}</span>
                {it.pill && <span class="ml-auto rounded-full bg-coral px-2 py-0.5 font-mono text-[10px] font-bold text-paper">{it.pill}</span>}
              </a>
            ))}
          </div>
        ))}
      </nav>

      <!-- Profile / auth -->
      <div class="border-t-zine border-ink p-3">
        <SidebarUser client:load />
      </div>
    </aside>

    <!-- Main column -->
    <div class="flex min-w-0 flex-1 flex-col">
      <!-- Page header -->
      <header class="sticky top-0 z-30 flex items-center gap-3 border-b-zine border-ink bg-paper2/95 px-4 py-3 backdrop-blur sm:px-6">
        <button id="dash-burger" type="button" aria-label="Open menu" class="flex h-9 w-9 items-center justify-center rounded-zineBadge border-zine border-ink bg-card shadow-zine-xs lg:hidden">
          <svg width="18" height="14" viewBox="0 0 18 14" aria-hidden="true"><path d="M1 1h16M1 7h16M1 13h16" stroke="var(--zine-ink)" stroke-width="2.4" stroke-linecap="round"></path></svg>
        </button>
        <div class="min-w-0">
          <h1 class="truncate font-display font-semibold text-[22px] leading-none text-ink">{heads}</h1>
          {subtitle && <p class="mt-1 truncate font-body font-bold text-[13px] text-inkSoft">{subtitle}</p>}
        </div>
        <a href="/dashboard/listings/new" class="ml-auto inline-flex items-center gap-1.5 rounded-full border-zine border-ink bg-lime px-4 py-2 font-mono font-bold uppercase text-[12px] tracking-[0.06em] text-ink no-underline shadow-zine-xs hover:-translate-y-[1px] transition-transform duration-zine">+ New</a>
      </header>

      <!-- Content -->
      <main class="mx-auto w-full max-w-6xl flex-1 px-4 py-6 sm:px-6 sm:py-8">
        <slot />
      </main>
    </div>
  </div>

  <script>
    const root = document.getElementById('dash-sidebar');
    const scrim = document.getElementById('dash-scrim');
    const open = () => { root?.classList.remove('-translate-x-full'); scrim?.classList.remove('hidden'); };
    const hide = () => { root?.classList.add('-translate-x-full'); scrim?.classList.add('hidden'); };
    document.getElementById('dash-burger')?.addEventListener('click', open);
    document.getElementById('dash-close')?.addEventListener('click', hide);
    scrim?.addEventListener('click', hide);
  </script>
</Base>
