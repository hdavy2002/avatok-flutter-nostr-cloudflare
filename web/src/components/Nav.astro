---
// Site header — replicates the old avatok.ai SiteHeader (the chrome that wraps
// the landing + every public page): a sticky cream bar with the teal-A logo +
// wordmark on the left, the primary nav in the middle, and auth-aware CTAs on
// the right (wallet pill + Open studio + Sign out, or Log in + Sign up). The
// right side is a small React island (HeaderCtas) since it depends on session.
import HeaderCtas from '../islands/site/HeaderCtas.tsx';

// Primary nav — mirrors the old site (Live streaming · Marketplace · How it
// works · Earnings · FAQ). The last three are landing-page anchors.
const links: { href: string; label: string }[] = [
  { href: '/marketplace?kind=live', label: 'Live streaming' },
  { href: '/marketplace', label: 'Marketplace' },
  { href: '/#how', label: 'How it works' },
  { href: '/#earnings', label: 'Earnings' },
  { href: '/#faq', label: 'FAQ' },
];
const linkClass =
  'font-body font-extrabold text-[14px] text-inkSoft hover:text-ink no-underline transition-colors';
---

<header class="sticky top-0 z-40 border-b-zine border-ink bg-paper2/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center gap-5 px-4 py-3">
    <a href="/" class="flex items-center gap-2 no-underline" aria-label="avatok.ai home">
      <img src="/avatok-logo.svg" alt="" width="34" height="32" class="h-[32px] w-auto" />
      <span class="font-display font-semibold text-[22px] leading-none tracking-[-0.4px] text-ink">
        ava<span class="text-blueInk">tok</span>
      </span>
    </a>

    <!-- Center nav (desktop) -->
    <nav class="hidden items-center gap-6 lg:flex">
      {links.map((l) => <a href={l.href} class={linkClass}>{l.label}</a>)}
    </nav>

    <!-- Right CTAs -->
    <div class="ml-auto hidden items-center gap-2 sm:flex">
      <a href="/admin" data-admin-link hidden class="font-mono font-bold uppercase text-[11px] tracking-[0.06em] text-inkSoft no-underline">Admin</a>
      <HeaderCtas client:load />
    </div>

    <!-- Mobile hamburger -->
    <button
      id="nav-burger"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      class="ml-auto flex h-9 w-9 items-center justify-center rounded-zineBadge border-zine border-ink bg-card shadow-zine-xs sm:hidden"
    >
      <svg width="18" height="14" viewBox="0 0 18 14" aria-hidden="true">
        <path d="M1 1h16M1 7h16M1 13h16" stroke="var(--zine-ink)" stroke-width="2.4" stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile sheet -->
  <div id="nav-sheet" class="hidden border-t-zine border-ink bg-paper2 sm:hidden">
    <div class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-3">
      {links.map((l) => (
        <a href={l.href} class="rounded-zineField px-3 py-2.5 font-body font-extrabold text-[15px] text-ink no-underline hover:bg-card">{l.label}</a>
      ))}
      <div class="mt-2 flex gap-2 border-t-zine border-ink pt-3">
        <a href="/sign-in" class="flex-1 rounded-full border-zine border-ink bg-card px-3 py-2.5 text-center font-mono font-bold uppercase text-[12px] tracking-[0.06em] text-ink no-underline shadow-zine-xs">Log in</a>
        <a href="/sign-up" class="flex-1 rounded-full border-zine border-ink bg-lime px-3 py-2.5 text-center font-mono font-bold uppercase text-[12px] tracking-[0.06em] text-ink no-underline shadow-zine-xs">Sign up</a>
      </div>
    </div>
  </div>

  <script>
    const burger = document.getElementById('nav-burger');
    const sheet = document.getElementById('nav-sheet');
    burger?.addEventListener('click', () => {
      const open = sheet?.classList.toggle('hidden') === false;
      burger.setAttribute('aria-expanded', String(open));
      burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    });
    try {
      if (localStorage.getItem('avatok_is_admin') === '1') {
        document.querySelectorAll('[data-admin-link]').forEach((el) => el.removeAttribute('hidden'));
      }
    } catch (_) { /* ignore */ }
  </script>
</header>
