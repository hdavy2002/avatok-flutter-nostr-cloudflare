---
// Consumer dashboard — the signed-in fan's bookings, tickets and wallet.
// SSR shell only; the MyBookings island fetches per-session data client-side
// (it requires a session, so this page is never edge-cached for content).
export const prerender = false;

import Base from '../layouts/Base.astro';
import MyBookings from '../islands/dashboard/MyBookings.tsx';

// Per-user content — do not cache.
Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<Base title="My bookings · avatok.ai" description="Your upcoming and past bookings, tickets and wallet on avatok.ai.">
  <main class="mx-auto max-w-2xl px-4 py-8">
    <header class="mb-6">
      <span class="font-mono font-bold uppercase text-[12px] tracking-[0.1em] text-blueInk">Dashboard</span>
      <h1 class="mt-2 font-display font-semibold text-[34px] leading-tight text-ink">My bookings</h1>
    </header>
    <MyBookings client:load />
  </main>
</Base>
