---
// The marketplace IS the home page now (see src/pages/index.astro). This path is
// kept as a permanent redirect to `/` so existing links — Nav, footer, dashboard,
// shared deep links with ?category= / ?kind= — keep working.
export const prerender = false;

const qs = Astro.url.search; // includes leading "?" or ""
return Astro.redirect(`/${qs}`, 301);
---
