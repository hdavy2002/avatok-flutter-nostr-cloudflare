---
// Public marketplace (logged-out). Logged-in users are routed to the
// dashboard-wrapped /dashboard/marketplace by <AuthRedirect/>.
export const prerender = false;

import Base from '../layouts/Base.astro';
import AuthRedirect from '../components/AuthRedirect.astro';
import MarketplaceBrowse from '../components/MarketplaceBrowse.astro';

const category = Astro.url.searchParams.get('category') ?? undefined;
const kind = Astro.url.searchParams.get('kind') ?? undefined;

Astro.response.headers.set('Cache-Control', 'public, max-age=60, stale-while-revalidate=300');
---

<Base
  title="Marketplace · avatok.ai"
  description="Browse live streams, 1:1 sessions, events and AI agents from creators worldwide — no app required."
>
  <AuthRedirect slot="head" />
  <main class="mx-auto max-w-6xl px-4 py-2">
    <MarketplaceBrowse hrefBase="" category={category} kind={kind} showHero={true} showSplit={true} />
  </main>
</Base>
