---
// avatok.ai home — the AvaTok launch landing (AI receptionist · private number · AI messaging).
// The design ships as a self-contained, pre-resolved static document
// (src/landing/avatok-landing.html): the x-dc runtime and all webfonts are
// inlined, a #joinlist waitlist section is wired to POST /api/waitlist (Brevo),
// and the site footer (with the real /privacy, /terms, /cookies, /dmca, /about,
// /careers, /blog, /contact links) is ported from the previous design.
//
// We strip the document's own leading <!DOCTYPE html> and let Astro emit one,
// then drop the whole document in via set:html (opaque to the Astro compiler,
// so its {{ }} bindings and CSS braces pass through untouched). Fully static.
export const prerender = true;

import landingRaw from '../landing/avatok-landing.html?raw';
const landingHtml = landingRaw.replace(/^﻿?\s*<!doctype html>/i, '');
---

<Fragment set:html={landingHtml} />
