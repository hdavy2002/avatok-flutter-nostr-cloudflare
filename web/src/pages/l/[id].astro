---
// Public listing detail — SSR, edge-cached, link-preview friendly. Logged-in
// users are routed to /dashboard/l/<id> by <AuthRedirect/>. Booking leads to
// sign-up first (?next=this listing) so they return here inside the dashboard.
export const prerender = false;

import Base from '../../layouts/Base.astro';
import AuthRedirect from '../../components/AuthRedirect.astro';
import ListingDetailView from '../../components/ListingDetailView.astro';
import { getListing, ApiError } from '../../lib/apiClient';
import { listingOg } from '../../lib/og';
import type { Listing } from '../../lib/types';

const { id } = Astro.params;

let listing: Listing | null = null;
let notFound = false;
try {
  listing = await getListing(id!);
} catch (e) {
  if (e instanceof ApiError && (e.status === 404 || e.status === 410)) notFound = true;
  else throw e;
}
if (notFound || !listing) return new Response('Listing not found', { status: 404 });

Astro.response.headers.set('Cache-Control', 'public, max-age=60, stale-while-revalidate=300');
const og = listingOg(listing);
---

<Base title={og.title} description={og.description} image={og.image}>
  <AuthRedirect slot="head" />
  {og.extra.map((m) => (m.property ? <meta property={m.property} content={m.content} slot="head" /> : <meta name={m.name} content={m.content} slot="head" />))}
  <ListingDetailView listing={listing} mode="public" />
</Base>
