---
// /dashboard/library — saved media & files (app: AvaLibrary).
export const prerender = false;

import Dashboard from '../../layouts/Dashboard.astro';
---

<Dashboard title="Library · avatok.ai" active="library">
  <header class="mb-6">
    <span class="font-mono font-bold uppercase text-[12px] tracking-[0.1em] text-blueInk">Dashboard</span>
    <h1 class="mt-2 font-display font-semibold text-[30px] leading-tight text-ink">Library</h1>
  </header>
  <div class="rounded-zine border-zine border-ink bg-card p-8 text-center shadow-zine-sm">
    <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-zineBadge border-zine border-ink bg-mint text-[22px] shadow-zine-xs">▤</div>
    <h2 class="font-display font-semibold text-[20px] text-ink">Your saved media & files</h2>
    <p class="mx-auto mt-2 max-w-md font-body font-bold text-[15px] text-inkSoft">
      Files you save across avatok live here — one shared pool, 5&nbsp;GB free. Uploading and managing your
      library is rolling out to the web next; for now it's available in the app.
    </p>
    <a href="/marketplace" class="mt-5 inline-block rounded-full border-zine border-ink bg-paper px-5 py-2.5 font-mono font-bold uppercase text-[12px] tracking-[0.06em] text-ink no-underline shadow-zine-xs">Back to marketplace</a>
  </div>
</Dashboard>
