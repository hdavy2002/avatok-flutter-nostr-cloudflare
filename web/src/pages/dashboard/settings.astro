---
// /dashboard/settings — account, identity/KYC level, profile (app: Settings/Identity).
export const prerender = false;

import Dashboard from '../../layouts/Dashboard.astro';
import SettingsPanel from '../../islands/dashboard/SettingsPanel.tsx';
---

<Dashboard title="Settings · avatok.ai" active="settings">
  <header class="mb-6">
    <span class="font-mono font-bold uppercase text-[12px] tracking-[0.1em] text-blueInk">Dashboard</span>
    <h1 class="mt-2 font-display font-semibold text-[30px] leading-tight text-ink">Settings</h1>
  </header>
  <SettingsPanel client:load />
</Dashboard>
