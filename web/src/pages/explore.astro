---
// `/explore` is the OLD marketplace path. The marketplace now lives at
// `/marketplace` (mobile-parity IA). Permanent-redirect, preserving any query
// (?category=, ?kind=) so existing shared links keep working.
export const prerender = false;

const qs = Astro.url.search; // includes leading "?" or ""
return Astro.redirect(`/marketplace${qs}`, 301);
---
