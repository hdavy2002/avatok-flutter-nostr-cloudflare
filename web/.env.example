# avatok.ai web client — environment.
# Copy to `.env` for local dev. PUBLIC_* vars are exposed to the browser bundle.

# API base (the SAME Worker the Flutter app calls). Prod is the default in
# src/lib/config.ts; override here for staging.
PUBLIC_API_BASE=https://api.avatok.ai
# Staging: https://api-staging.avatok.ai

# Clerk publishable key for web auth/session (pk_test_… or pk_live_…).
# Get it from the Clerk dashboard. Required for any auth'd island / GuestGate.
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
