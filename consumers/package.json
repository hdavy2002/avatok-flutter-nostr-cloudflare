{
  "name": "avatok-consumers",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "dry-run": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "echo '[ENV-ISOLATION-1] `npm run deploy` is disabled: it deployed to PRODUCTION with no warning. Use `npm run deploy:staging` (safe) or `npm run deploy:prod` (requires ALLOW_PROD=1).' && exit 1",
    "deploy:staging": "AVATOK_TARGET=staging ../scripts/cf.sh consumers deploy",
    "deploy:prod": "AVATOK_TARGET=prod ../scripts/cf.sh consumers deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250510.0",
    "eslint": "^9.9.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@cf-wasm/photon": "^0.3.6"
  }
}
