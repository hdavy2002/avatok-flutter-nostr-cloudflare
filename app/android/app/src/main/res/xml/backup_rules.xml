<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup rules (Android 11 and below; android:fullBackupContent).

  ROOT-CAUSE FIX: flutter_secure_storage stores its values in the
  `FlutterSecureStorage` EncryptedSharedPreferences file, but the AES key that
  decrypts them lives in the Android Keystore, which is NEVER part of a backup.
  If Auto Backup restores the ciphertext (new install, "restore from backup",
  device transfer) the matching Keystore key is gone, so the first read throws
  `BadPaddingException` / `BAD_DECRYPT` and the app can't load the account.
  Excluding the secure-storage prefs from backup stops the corruption at source;
  the app re-provisions those keys from the server on next launch.
-->

<!--
  [AVADIAL-BACKUP-RESTOREFIRST 2026-07-15] `cache/` (DiskCache) is excluded for the
  same reason as in data_extraction_rules.xml — keep the two files in step.

  It holds device-LOCAL facts: "this device has already uploaded a contact backup"
  and "this account owns this handset's phone book". Restored onto a NEW phone, both
  are false but believed: the first opens the restore-first hold so the automatic
  upload overwrites the user's cloud backup before they can restore it, and the
  second leaves a former sub marked as a sub on the phone they just bought. A cache
  that describes a handset must not follow the user to a different handset.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="FlutterSecureStorage.xml"/>
    <exclude domain="file" path="cache/"/>
</full-backup-content>
