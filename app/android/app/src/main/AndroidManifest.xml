<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="com.sec.android.provider.badge.permission.READ" />
    <uses-permission android:name="com.sec.android.provider.badge.permission.WRITE" />
    <uses-permission android:name="com.htc.launcher.permission.READ_SETTINGS" />
    <uses-permission android:name="com.htc.launcher.permission.UPDATE_SHORTCUT" />
    <uses-permission android:name="com.sonyericsson.home.permission.BROADCAST_BADGE" />
    <uses-permission android:name="com.sonymobile.home.permission.PROVIDER_INSERT_BADGE" />
    <uses-permission android:name="com.anddoes.launcher.permission.UPDATE_COUNT" />
    <uses-permission android:name="com.majeur.launcher.permission.UPDATE_BADGE" />
    <uses-permission android:name="com.huawei.android.launcher.permission.CHANGE_BADGE" />
    <uses-permission android:name="com.huawei.android.launcher.permission.READ_SETTINGS" />
    <uses-permission android:name="com.huawei.android.launcher.permission.WRITE_SETTINGS" />
    <uses-permission android:name="me.everything.badger.permission.BADGE_COUNT_READ" />
    <uses-permission android:name="me.everything.badger.permission.BADGE_COUNT_WRITE" />
    <uses-permission android:name="com.oppo.launcher.permission.READ_SETTINGS" />
    <uses-permission android:name="com.oppo.launcher.permission.WRITE_SETTINGS" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- [AVADIAL-OTP-1] Draw the Truecaller-style floating OTP card OVER other apps
         so the user copies a one-time code without opening AvaTOK. User-granted via
         the setup sheet ("appear on top"); the OTP falls back to a heads-up copy
         notification until it's granted. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- CALL-BG-B4: required on Android 14+ (API 34) to declare "camera" in the
         call service's foregroundServiceType for video calls. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- AvaDial PSTN dialer (Specs/SPIKE-2026-07-12-avadial-telecom.md). All DARK
         behind the Flutter `avaDialer` flag. READ_CALL_LOG + READ_CONTACTS power the
         Logs/Contacts tabs + the green/red screen paint; CALL_PHONE places carrier
         calls via TelecomManager.placeCall; ANSWER_PHONE_CALLS + READ_PHONE_STATE
         drive the InCallService. MANAGE_OWN_CALLS is already declared above (used by
         the in-network VoIP path) and is NOT what makes us the default dialer — the
         ROLE_DIALER role does that at runtime. -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- AvaDial default-SMS-app layer (AVA-SMS). All DARK behind the Flutter
         `avaSms` flag: these components only become active when the user grants
         ROLE_SMS, which we never request unless the flag is on. SEND_SMS sends;
         RECEIVE_SMS + BROADCAST_SMS deliver inbound text to AvaSmsReceiver;
         RECEIVE_MMS/RECEIVE_WAP_PUSH deliver MMS pushes to AvaMmsReceiver; READ_SMS
         reads the conversation list/threads from the OS provider. These are
         Play-"restricted" SMS permissions — AvaTOK must file the default-SMS-handler
         Permissions Declaration (see Specs/SPIKE-2026-07-12-avadial-telecom.md). -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_MMS" />
    <uses-permission android:name="android.permission.RECEIVE_WAP_PUSH" />

    <application
        android:label="AvaTOK"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules">
        <!-- [ISSUE-DUPTASK] Recents duplication — corrected diagnosis.
             The old comment here claimed flutter_callkit_incoming's call activity
             uses the default package affinity, and that giving MainActivity an
             empty affinity was therefore what split them into two tasks. That was
             WRONG. The plugin declares CallkitIncomingActivity with
             launchMode="singleInstance" AND its own dedicated
             taskAffinity="com.hiennv.flutter_callkit_incoming.INCOMING_CALL_AFFINITY",
             so it is ALWAYS in its own task no matter what MainActivity does.
             Removing the empty affinity could never have merged them, which is why
             the second Recents card kept coming back. Two real fixes:
               1. Below: MainActivity is singleTask, not singleTop. The ongoing-call
                  notification relaunches it with FLAG_ACTIVITY_NEW_TASK from a
                  service context (CallForegroundService.kt); a NEW_TASK launch of a
                  singleTop activity can spawn a SECOND MainActivity task instead of
                  reusing the existing one. singleTask forces task reuse.
               2. Further down: we merge autoRemoveFromRecents onto the plugin's
                  CallkitIncomingActivity so its task disappears when the ring
                  activity finishes. The plugin's excludeFromRecents + noHistory are
                  honoured on stock Android but unreliable on the Samsung/Oppo/
                  Huawei/Xiaomi launchers we target (see badge permissions above). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Phase 5 (A1): Android App Links — https://avatok.ai/j/<token>
                 opens the app directly (verified via /.well-known/assetlinks.json). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="avatok.ai" android:pathPrefix="/j/"/>
            </intent-filter>
            <!-- App Link — https://avatok.ai/add?t=<token> opens the app to the
                 "add contact" card (AvaTOK Number QR share). Same host as /j/, so
                 the existing /.well-known/assetlinks.json verifies it too. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="avatok.ai" android:pathPrefix="/add"/>
            </intent-filter>
            <!-- Custom-scheme deeplink fallback (avatok://booking/<id>, avatok://add?t=). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="avatok"/>
            </intent-filter>
        </activity>
        <!-- [AVADIAL-NATIVE-RING-1] Dedicated native incoming-PSTN-call screen.
             Lives in its OWN task (taskAffinity) so ringing NEVER opens the app's
             task/landing page/setup sheet; excludeFromRecents + autoRemoveFromRecents
             so no ghost card lingers after the call; showWhenLocked + turnScreenOn so
             it rings over the lock screen. Launched only by AvaInCallService / the
             full-screen-intent notification — never exported. -->
        <activity
            android:name="ai.avatok.avadial.IncomingCallActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:taskAffinity="ai.avatok.avadial.incoming"
            android:excludeFromRecents="true"
            android:autoRemoveFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|screenLayout|density|uiMode"
            android:theme="@android:style/Theme.Material.NoActionBar" />
        <!-- [ISSUE-DUPTASK] Merge-override of flutter_callkit_incoming's ring
             activity. We do NOT change its launchMode or taskAffinity (singleInstance
             on a dedicated affinity is what lets it show over the lock screen), we
             only add autoRemoveFromRecents so the task it creates is torn down as
             soon as the ring activity finishes — killing the ghost card that lingers
             after a call on OEM launchers. These attributes are absent upstream, so
             the manifest merger adds them without needing tools:replace.
             tools:node="merge" keeps the plugin's own declaration intact. -->
        <activity
            android:name="com.hiennv.flutter_callkit_incoming.CallkitIncomingActivity"
            android:autoRemoveFromRecents="true"
            android:excludeFromRecents="true"
            tools:node="merge" />
        <activity
            android:name="com.hiennv.flutter_callkit_incoming.TransparentActivity"
            android:autoRemoveFromRecents="true"
            android:excludeFromRecents="true"
            tools:node="merge" />

        <!-- [AVATOK-VOIP-TC-1] Keep AvaTOK P2P VoIP calls OUT of the Android Telecom
             framework. flutter_callkit_incoming ships a self-managed
             CallkitConnectionService (BIND_TELECOM_CONNECTION_SERVICE +
             android.telecom.ConnectionService); with MANAGE_OWN_CALLS declared, every
             VoIP ring is reported to Telecom as a system call. Third-party caller-ID /
             call-screening apps (e.g. Truecaller) observe that Telecom call and paint
             their own overlay BEHIND our ring — both bound to the same call object, so
             declining tears the connection down and Truecaller dismisses in lockstep.
             AvaTOK P2P (VoIP + AI answering machine) is a SEPARATE product from AvaDial
             (PSTN/SMS); it needs only the notification + CallkitIncomingActivity
             full-screen UI, and its audio is owned by WebRTC + CallForegroundService,
             NOT the Telecom connection. Removing this service declaration leaves Telecom
             nothing to bind, so the call stays in-app and invisible to other dialers.
             MANAGE_OWN_CALLS is intentionally KEPT (full-screen-intent priority on
             Android 14+). Does NOT touch AvaDial's own telecom services (ai.avatok.avadial
             AvaInCallService / AvaCallScreeningService) — different components entirely. -->
        <service
            android:name="com.hiennv.flutter_callkit_incoming.CallkitConnectionService"
            tools:node="remove" />

        <!-- flutter_web_auth_2 callback for the avatokauth:// OAuth return
             (AvaStorage "Connect Google Drive"). Lets the in-app auth tab
             auto-close and hand control straight back to the app. Distinct from
             the "avatok" deeplink scheme above. -->
        <activity
            android:name="com.linusu.flutter_web_auth_2.CallbackActivity"
            android:exported="true">
            <intent-filter android:label="flutter_web_auth_2">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="avatokauth" />
            </intent-filter>
        </activity>
        <!-- CALLFIX-20 / CALL-BG-B4: Foreground service for ongoing calls (keeps VoIP
             calls alive while backgrounded). Declares phoneCall|microphone|camera so
             BOTH audio-only and video calls are covered — Android 14+ (API 34)
             requires every type actually started via ServiceCompat.startForeground to
             be pre-declared here; audio calls simply never pass the camera bit at
             runtime. android:stopWithTask defaults to false (unset = false), i.e. the
             service is NOT killed when the app's task is removed from Recents — this
             is required for the call to survive the user swiping the app away. -->
        <service
            android:name="ai.avatok.avavoiceaudio.CallForegroundService"
            android:foregroundServiceType="phoneCall|microphone|camera"
            android:stopWithTask="false"
            android:exported="false" />
        <!-- ── AvaDial telecom layer (DARK behind the `avaDialer` flag) ──────────
             All three components below only become active when the user grants the
             ROLE_DIALER / ROLE_CALL_SCREENING roles, which we never request unless
             the flag is on. See Specs/SPIKE-2026-07-12-avadial-telecom.md. -->

        <!-- Default-dialer in-call surface. exported + BIND_INCALL_SERVICE +
             IN_CALL_SERVICE_UI so the OS binds us for PSTN calls once ROLE_DIALER is
             held. We do NOT set IN_CALL_SERVICE_RINGING (Phase 2b leaves ringing to
             the system). -->
        <service
            android:name="ai.avatok.avadial.AvaInCallService"
            android:exported="true"
            android:permission="android.permission.BIND_INCALL_SERVICE">
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_UI"
                android:value="true" />
            <intent-filter>
                <action android:name="android.telecom.InCallService" />
            </intent-filter>
        </service>

        <!-- Spam call-screening. Granted via ROLE_CALL_SCREENING (independent of the
             dialer role), so the shield works even when the user keeps another phone
             app. Reads the local snapshot only — never the network. -->
        <service
            android:name="ai.avatok.avadial.AvaCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!-- ACTION_DIAL / tel: activity-alias — the dialer role requires an activity
             that can handle dial intents. Aliases the existing MainActivity so we
             satisfy the requirement without a second Flutter activity. -->
        <activity-alias
            android:name="ai.avatok.avadial.DialAlias"
            android:targetActivity=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.DIAL" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.DIAL" />
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="tel" />
            </intent-filter>
        </activity-alias>

        <!-- ── AvaDial default-SMS-app layer (DARK behind the `avaSms` flag) ──────
             The four components below are ALL MANDATORY for ROLE_SMS: Android's
             role request silently fails to offer AvaTOK as an SMS app unless the
             app declares (1) an SMS_DELIVER receiver, (2) a WAP_PUSH_DELIVER
             receiver for MMS, (3) a RESPOND_VIA_MESSAGE service, and (4) an
             ACTION_SENDTO activity for sms:/smsto:/mms:/mmsto:. This mirrors the
             canonical default-SMS-app manifest at
             https://developer.android.com/reference/android/provider/Telephony .
             None fires until the user grants ROLE_SMS, which we never request
             unless the flag is on. See Specs/SPIKE-2026-07-12-avadial-telecom.md. -->

        <!-- (1) Inbound SMS. BROADCAST_SMS-protected; the OS delivers here only while
             we are the default SMS app. -->
        <receiver
            android:name="ai.avatok.avadial.AvaSmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_DELIVER" />
            </intent-filter>
        </receiver>

        <!-- [AVADIAL-OTP-1] Handles the "Copy code" action on the OTP heads-up
             pop-up (AvaSmsReceiver.notifyOtp). NOT exported — only our own
             notification action fires it. -->
        <receiver
            android:name="ai.avatok.avadial.AvaOtpCopyReceiver"
            android:exported="false" />

        <!-- [AVADIAL-HARDEN-1] Handles the Answer/Decline actions on the incoming-call
             notification (AvaInCallService.launchIncoming). Not exported — only our
             own notification actions trigger it. -->
        <receiver
            android:name="ai.avatok.avadial.AvaCallActionReceiver"
            android:exported="false" />

        <!-- [AVA-MISSEDCALL-1] Truecaller-style missed-call detector. Listens for the
             system PHONE_STATE broadcast (RINGING→IDLE without OFFHOOK = missed) and
             raises AvaMissedCallOverlay. exported=true because the OS is the broadcaster;
             READ_PHONE_STATE (declared above) is what authorises delivery. Fully DARK
             until Dart writes {enabled:true} into missedcall_config.json, which it only
             does when the `missedCallOverlay` flag is on AND "appear on top" is granted —
             so onReceive early-returns on every device until the owner ships the feature.
             Uses SYSTEM_ALERT_WINDOW + READ_CALL_LOG (both already declared). -->
        <receiver
            android:name="ai.avatok.avadial.AvaMissedCallReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- (2) Inbound MMS (WAP push). BROADCAST_WAP_PUSH-protected. -->
        <receiver
            android:name="ai.avatok.avadial.AvaMmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_WAP_PUSH">
            <intent-filter>
                <action android:name="android.provider.Telephony.WAP_PUSH_DELIVER" />
                <data android:mimeType="application/vnd.wap.mms-message" />
            </intent-filter>
        </receiver>

        <!-- (3) "Respond via message" quick-reply service. -->
        <service
            android:name="ai.avatok.avadial.AvaSmsSendService"
            android:exported="true"
            android:permission="android.permission.SEND_RESPOND_VIA_MESSAGE_SERVICE">
            <intent-filter>
                <action android:name="android.intent.action.RESPOND_VIA_MESSAGE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </service>

        <!-- (4) ACTION_SENDTO compose activity-alias — aliases MainActivity with a
             route extra so a tapped sms:/smsto: link (or another app's "send
             message") opens the AvaDial composer. -->
        <activity-alias
            android:name="ai.avatok.avadial.SmsComposeAlias"
            android:targetActivity=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.SENDTO" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </activity-alias>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Required (Android 11+) so the native speech recognizer is visible to
             speech_to_text; without it initialize() fails and STT falls back to
             cloud Whisper. -->
        <intent>
            <action android:name="android.speech.RecognitionService"/>
        </intent>
        <!-- AvaDial: resolve dial intents (Android 11+ package visibility) so we can
             place PSTN calls / detect other dialers. -->
        <intent>
            <action android:name="android.intent.action.DIAL"/>
            <data android:scheme="tel"/>
        </intent>
        <!-- AvaDial: resolve SMS send intents so we can detect other messaging apps. -->
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="smsto"/>
        </intent>
        <!-- [AVADIAL-SETUP-1] Explicit package visibility (Android 11+) for known
             third-party caller-ID / dialer apps that draw their own overlay, so the
             setup sheet can DETECT the installed ones (getApplicationInfo) and
             deep-link straight to each one's settings. We can only detect + link —
             Android never lets one app disable or revoke another. Keep this list in
             sync with knownRivalPackages in AvaDialPlugin.kt. -->
        <package android:name="com.truecaller" />
        <package android:name="mobi.drupe.app" />
        <package android:name="com.callapp.contacts" />
        <package android:name="com.eyecon.global" />
        <package android:name="com.hiya.star" />
        <package android:name="gogolook.callgogolook2" />
    </queries>
</manifest>
