# TEMPLATE — copy to wrangler.toml and fill in your own Cloudflare resource IDs.
# Real IDs (D1 / KV / account / app) are infrastructure identifiers, not secrets,
# but should NOT be published in a public repo. All true secrets (API tokens,
# LIVEKIT_API_SECRET, REVIEW_PASSWORD, etc.) are set with `wrangler secret put`
# and never live in this file.

name = "avatok-api"
main = "src/index.ts"
compatibility_date = "2025-05-01"
compatibility_flags = ["nodejs_compat"]

[[routes]]
pattern = "api.example.com"          # your custom domain
custom_domain = true

[vars]
BLOSSOM_BASE_URL = "https://blossom.example.com"
FCM_PROJECT = "your-fcm-project"
# ... non-secret feature flags / model ids go here ...
WALLET_TOPUP_ENABLED = "0"
CLERK_JWKS_URL = "https://clerk.example.com/.well-known/jwks.json"
CLERK_ISSUER = "https://clerk.example.com"
ADMIN_UIDS = "REPLACE_WITH_ADMIN_CLERK_UIDS"
LIVEKIT_URL = "wss://YOUR-PROJECT.livekit.cloud"
PLAY_PACKAGE_ID = "com.example.app"

# --- D1 databases: fill database_id after `wrangler d1 create` ---
[[d1_databases]]
binding = "DB_META"
database_name = "avatok-meta"
database_id = "REPLACE_WITH_YOUR_D1_DATABASE_ID"

# Repeat the [[d1_databases]] / [[kv_namespaces]] / [[r2_buckets]] / [[vectorize]]
# blocks from your private wrangler.toml, replacing every *_id with your own.
