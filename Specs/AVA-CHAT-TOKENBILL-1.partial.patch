+    // [AVA-CHAT-TOKENBILL-1] Per-user chat-token accrual. `accrued` = model
+    // tokens (in+out) not yet billed; `charge_seq` = monotonic counter so every
+    // wallet spend gets a unique, idempotent op_id (a DO replay can never
+    // double-charge — WalletDO dedupes on op_id). Coins are integer (1 = $0.01),
+    // so we accrue until at least one whole coin is owed, then charge.
+    this.sql.exec(
+      `CREATE TABLE IF NOT EXISTS ava_token_billing (
+         uid TEXT PRIMARY KEY,
+         accrued INTEGER NOT NULL DEFAULT 0,
+         charge_seq INTEGER NOT NULL DEFAULT 0,
+         updated_at INTEGER NOT NULL DEFAULT 0
+       );`,
+    );
+  }
+
+  // ---- [AVA-CHAT-TOKENBILL-1] chat token metering → wallet ----------------------
+  private billingRow(uid: string): { accrued: number; charge_seq: number } {
+    const r = this.sql.exec(
+      "SELECT accrued, charge_seq FROM ava_token_billing WHERE uid = ?", uid,
+    ).toArray()[0] as any;
+    return r ? { accrued: Number(r.accrued) || 0, charge_seq: Number(r.charge_seq) || 0 }
+             : { accrued: 0, charge_seq: 0 };
+  }
+
+  private saveBillingRow(uid: string, accrued: number, chargeSeq: number): void {
+    this.sql.exec(
+      `INSERT INTO ava_token_billing (uid, accrued, charge_seq, updated_at)
+       VALUES (?1, ?2, ?3, ?4)
+       ON CONFLICT(uid) DO UPDATE SET accrued=?2, charge_seq=?3, updated_at=?4`,
+      uid, Math.max(0, Math.trunc(accrued)), Math.max(0, Math.trunc(chargeSeq)), Date.now(),
+    );
+  }
+
+  /**
+   * Accrue `used` model tokens for `uid` and deduct whole coins from the wallet
+   * once ≥ 1 coin is owed. Rate: cfg.avaChatCoinsPerMTok coins per 1M tokens
+   * (default 100 → 1 coin per 10,000 tokens). Runs AFTER the reply is delivered
+   * — a billing hiccup never blacks out @ava; unbilled tokens stay accrued and
+   * are collected on a later turn (see the debt gate in turn()).
+   * Charging is a no-op while betaFreePremium is on unless avaChatBillingLive
+   * (forceMeter — same pattern as [RECEPT-BILLING-LIVE-1]).
+   */
+  private async meterChatTokens(
+    uid: string, email: string, phone: string, used: number,
+    cfg: { avaChatCoinsPerMTok: number; avaChatBillingLive: boolean },
+  ): Promise<void> {
+    const add = Math.max(0, Math.trunc(used));
+    if (!add) return;
+    const perMTok = Math.max(1, Number(cfg.avaChatCoinsPerMTok) || 100);
+    const tokensPerCoin = Math.max(1, Math.floor(1_000_000 / perMTok));
+    const row = this.billingRow(uid);
+    let accrued = row.accrued + add;
+    const coins = Math.floor(accrued / tokensPerCoin);
+    if (coins <= 0) { this.saveBillingRow(uid, accrued, row.charge_seq); return; }
+    const seq = row.charge_seq + 1;
+    // Persist the seq BEFORE the network call so a DO restart mid-charge reuses
+    // the SAME op_id on retry (WalletDO dedupes) instead of minting a new one.
+    this.saveBillingRow(uid, accrued, seq);
+    const opId = `avachat:${uid}:${seq}`;
+    try {
+      const r = await chargeAmount(this.env, uid, "ava_chat_tokens", coins, opId, {
+        forceMeter: !!cfg.avaChatBillingLive,
+        meta: { category: "ava", context: `Ava chat — ${coins * tokensPerCoin} AI tokens` },
+      });
+      if (r.ok) {
+        accrued -= coins * tokensPerCoin;
+        this.saveBillingRow(uid, accrued, seq);
+      }
+      trackUserContact(this.env, uid, email, phone, "ava_chat_billing", "avaai", {
+        tokens_used: add, tokens_accrued: accrued, coins_due: coins,
+        charged: r.ok ? (r.charged ?? 0) : 0, ok: r.ok, reason: r.reason ?? null,
+        live: !!cfg.avaChatBillingLive, coins_per_mtok: perMTok,
+      });
+    } catch (e: any) {
+      // Accrual (incl. seq) is already persisted — tokens are owed, not lost.
+      trackUserContact(this.env, uid, email, phone, "ava_chat_billing", "avaai", {
+        tokens_used: add, tokens_accrued: accrued, coins_due: coins,
+        charged: 0, ok: false, reason: String(e?.message ?? e).slice(0, 160),
+        live: !!cfg.avaChatBillingLive, coins_per_mtok: perMTok,
+      });
+    }
   }
 
